{
  "name": "ai-helper-app",
  "private": true,
  "version": "0.1.1",
  "description": "本地部署的个人 AI 助手（对话/编程Agent/本地模型/联网/文件）",
  "author": "Lenssansi",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && electron .",
    "dev": "concurrently -k -n vite,electron \"npm:dev:vite\" \"npm:dev:electron\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.aihelper.app",
    "productName": "ai-helper",
    "directories": { "output": "../release/v${version}" },
    "files": ["dist/**/*", "electron/**/*", "package.json"],
    "extraResources": [
      { "from": "../backend/dist/ai-helper-backend.exe",
        "to": "backend/ai-helper-backend.exe" },
      { "from": "../skills", "to": "skills",
        "filter": ["**/*", "!**/.git/**"] }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "../assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "differentialPackage": false,
      "installerLanguages": ["zh_CN", "en_US"],
      "menuCategory": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "ai-helper"
    }
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "mermaid": "^11.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wait-on": "^8.0.2"
  }
}
